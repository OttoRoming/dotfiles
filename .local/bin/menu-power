#!/usr/bin/env bash

lock="пЂЈ lock"
logout="у°Ђ„ logout"
reboot="о«’ reboot"
poweroff="вЏ» poweroff"

choice=$(printf '%s\n%s\n%s\n%s\n' "$lock" "$logout" "$reboot" "$poweroff" | "$HOME/.local/bin/menu")
[ "$choice" == "$lock" ] && /home/otto/.config/bin/lock
[ "$choice" == "$logout" ] && pkill mango
[ "$choice" == "$reboot" ] && systemctl reboot
[ "$choice" == "$poweroff" ] && systemctl poweroff
